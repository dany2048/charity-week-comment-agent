# Copy to .env (gitignored) and fill in. Source before running the scripts.
# Single-account model: ONE contentbase1 OAuth login covers YouTube + Sheets.

# --- Google OAuth (Desktop client, YouTube Data API v3 + Sheets API enabled) ---
# Account = contentbase1 (manager on the CW channel; owns the approval sheet).
CW_GOOGLE_CLIENT_SECRET=state/client_secret.json
CW_GOOGLE_TOKEN=state/token.json
# The Charity Week YouTube channel id (UC...). From youtube.com/@CharityWeek.
CW_YT_CHANNEL_ID=

# --- Approval Google Sheet (create with: python create_sheet.py) ---
CW_APPROVAL_WORKSHEET=Replies
CW_APPROVAL_SHEET_ID=
CW_APPROVAL_SHEET_URL=

# --- misc ---
CW_STATE_DIR=state
